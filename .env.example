# Copy to .env.local and fill in from Supabase → Settings → API.
# (Vite exposes only VITE_*-prefixed vars to the browser — never put the
#  service-role key here; it lives only in the Edge Function's secrets.)
VITE_SUPABASE_URL=https://YOUR-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
